---
import { Font, getImage, Picture } from "astro:assets";
import "../styles/global.css";
import DialogCloseButton from "@components/DialogCloseButton.astro";
import prewiredLogoText from "@assets/logos/prewired-logo-text.png";


interface Props {
	title: string;
	ogTitle?: string; // Set if the OG title should be different from the HTML title
	desc: string;
	type: "website" | "article";
	author?: string;
	coverImageData: ImageMetadata;
	coverImageAlt: string;
}

const { title, ogTitle, desc, type, author, coverImageData, coverImageAlt } = Astro.props;

const navItems = [
	{ href: "/news/", title: "News", accent: "blue" },
	{ href: "/activities/", title: "Activities", accent: "purple" },
	{ href: "/resources/", title: "Resources", accent: "pink" },
	{ href: "/volunteering/", title: "Volunteering", accent: "blue" },
	{ href: "/support/", title: "Support us", accent: "purple" },
	{ href: "/about/", title: "About", accent: "pink" },
	{ href: "/contact/", title: "Contact", accent: "blue" },
];

// Get the URL for this page
const { url } = Astro;

// Get a static URL for this page's cover image, for Open Graph use
const imgURL = new URL((await getImage({ src: coverImageData, format: coverImageData.format })).src, url).href;
---

<!DOCTYPE html>
<html lang="en-GB">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<meta name="description" content={desc} />
		{ author && <meta name="author" content={author} /> }
		<meta property="og:site_name" content="Prewired" />
		<meta property="og:url" content={url} />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={ogTitle ?? title} />
		<meta property="og:description" content={desc} />
		<meta property="og:locale" content="en_GB" />
		<meta property="og:image" content={imgURL} />
		<meta property="og:image:alt" content={coverImageAlt} />

		<title>{`${title} - Prewired`}</title>

		<Font cssVariable="--font-rubik" />
	</head>

	<body class="md:mx-4 md:border-x border-gray-200 bg-white lg:text-lg">
		<header class="sticky top-0 h-20 lg:h-24 px-4 flex items-center bg-white z-40 after:absolute after:w-full after:md:w-[calc(100%+2rem)] after:h-px after:bg-gray-200 after:left-0 after:md:-left-4 after:-bottom-px">
			<a href="/" class="mr-auto hover:opacity-70 transition">
				<Picture priority
					src={prewiredLogoText}
					formats={["avif", "webp"]}
					alt="The Prewired logo"
					width="160"
					class="pb-1"
				/>
			</a>
			<!-- Small-screen menu button -->
			<button
				class="lg:hidden flex items-center pl-3 pr-4 py-2 bg-pink-600 hover:bg-pink-800 border-b-2 border-pink-900 active:border-b-0 active:mt-0.5 rounded-lg uppercase font-semibold text-white cursor-pointer transition"
				id="menu-open-btn"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="mt-px mr-2 fill-white" viewBox="0 0 16 16">
					<path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
				</svg>
				Menu
			</button>
			<!-- Small-screen menu -->
			<dialog
				class="h-[200%] max-h-[200%] w-full sm:w-1/2 max-w-full sm:left-1/2 p-10 bg-pink-50 sm:border-l-2 sm:border-pink-600 translate-x-10 open:translate-x-0 starting:open:translate-x-10"
				id="menu-dialog"
			>
				<DialogCloseButton
					id="menu-dialog-close-btn"
					style="float-right clear-both"
				/>
				<nav class="flex flex-col items-center sm:items-start">
					<div class="mt-12 mb-8">
						<a href="/" class={`text-2xl text-black no-underline ${Astro.url.pathname === "/" ? "font-bold" : "hover:text-pink-600"}`}>
							Home
						</a>
					</div>
					{ navItems.map(({ href, title }) => (
						<div class="mb-8">
							<a href={href} class={`text-2xl text-black no-underline ${Astro.url.pathname === href ? "font-bold" : "hover:text-pink-600"}`}>
								{ title }
							</a>
						</div>
					))}
				</nav>
			</dialog>
			<!-- Large-screen menu -->
			<nav class="relative h-full mx-4 -mb-px hidden lg:flex gap-7 xl:gap-12 z-50">
				{ navItems.map(({ href, title, accent }) => (
					<a href={href} class={`pt-2 md:py-9 shrink-0 font-[450] text-black no-underline border-b-2 border-transparent
						${Astro.url.pathname === href ? 
							(accent === "pink" ? "text-pink-600 border-pink-600!" : accent === "purple" ? "text-purple-600 border-purple-600!" : "text-blue-750 border-blue-750!")
						: (accent === "pink" ? "hover:text-pink-600" : accent === "purple" ? "hover:text-purple-600" : "hover:text-blue-750")}
					`}>
						{ title }
					</a>
				))}
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<div class="h-16 border-t diastripe"></div>
		<footer class="relative bg-purple-50 before:absolute before:w-full before:md:w-[calc(100%+2rem)] before:h-px before:bg-gray-200 before:md:-left-4 before:top-0 after:absolute after:w-full after:md:w-[calc(100%+2rem)] after:h-px after:bg-gray-200 after:md:-left-4 after:-bottom-px">
			<div class="w-full max-w-360 mx-auto flex flex-wrap lg:justify-between 2xl:border-x sm:divide-x divide-y lg:divide-y-0 *:w-full sm:*:w-1/2 lg:*:w-1/4 *:py-6 md:*:py-10 *:px-4 md:*:px-8">
				<div class="pt-6! flex flex-col">
					<Picture
						src={prewiredLogoText}
						formats={["avif", "webp"]}
						alt="The Prewired logo"
						width="240"
						class="mb-8"
					/>
					<div class="flex flex-wrap lg:flex-col gap-4">
						<!-- Ko-fi widget -->
						<script is:inline type="text/javascript" src="https://storage.ko-fi.com/cdn/widget/Widget_2.js"></script>
						<script is:inline type="text/javascript">
							kofiwidget2.init("Support us on Ko-fi", "#EB004E", "S6S35YATV");
							kofiwidget2.draw();
						</script>
						<!-- End of Ko-fi widget -->
						<a
							href="http://eepurl.com/dv2dPb"
							target="_blank" rel="noopener"
							class="w-fit px-3.5 py-2.5 bg-purple-600 hover:bg-purple-800 rounded-md cursor-pointer font-medium text-sm text-white no-underline"
						>
							Join our mailing list
						</a>
					</div>
				</div>
				<div class="sm:max-lg:border-r-0">
					<h2>Policies</h2>
					<div class="flex flex-col text-base leading-7">
						<a href="/child-protection/">Child protection</a>
						<a href="/equality-diversity-inclusion/">Equality, diversity, and inclusion</a>
						<a href="/online-safety/">Online safety</a>
						<a href="/privacy/">Privacy</a>
						<a href="/use-of-computing-facilities/">Use of computing facilities</a>
					</div>
				</div>
				<div class="sm:max-lg:border-b-0">
					<h2>Visit us</h2>
					<address>
						CodeBase Edinburgh<br />
						37a Castle Terrace<br />
						Edinburgh EH1 2EL
					</address>
					<hr class="hidden lg:block w-[calc(100%+4rem)] -ml-8 mt-6 mb-8" />
					<div class="mt-4 lg:mt-0 flex gap-10">
						<!-- LinkedIn -->
						<a href="https://uk.linkedin.com/company/prewired" target="_blank" rel="noopener noreferrer">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" class="fill-purple-600 hover:fill-purple-800 active:fill-purple-500" viewBox="0 0 16 16">
								<title>LinkedIn</title>
								<path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
							</svg>
						</a>
						<!-- Facebook -->
						<a href="https://www.facebook.com/Prewired1" target="_blank" rel="noopener noreferrer">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" class="fill-purple-600 hover:fill-purple-800 active:fill-purple-500" viewBox="0 0 16 16">
								<title>Facebook</title>
								<path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
							</svg>
						</a>
						<!-- GitHub -->
						<a href="https://github.com/prewired" target="_blank" rel="noopener noreferrer">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" class="fill-purple-600 hover:fill-purple-800 active:fill-purple-500" viewBox="0 0 16 16">
								<title>GitHub</title>
								<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
							</svg>
						</a>
					</div>
				</div>
				<div>
					<h2>Correspondence to</h2>
					<address>
						Prewired &incare; CodeBase<br />
						Argyle House<br />
						3 Lady Lawson Street<br />
						Edinburgh EH3 9DR
					</address>
				</div>
			</div>
		</footer>
		<div class="w-full max-w-360 mx-auto py-4 md:py-0 flex flex-col md:flex-row 2xl:border-x text-base text-center">
			<div class="md:w-1/2 lg:w-1/3 md:py-4">
				Prewired is a Scottish Charity, <a href="https://www.oscr.org.uk/about-charities/search-the-register/charity-details?number=SC047780" target="_blank" rel="noopener">SC047780</a>
			</div>
			<div class="md:w-1/2 lg:w-1/3 md:py-4 md:border-l">
				&copy; 2026 Prewired
			</div>
			<div class="hidden lg:block w-1/3 py-4 border-l">
				<a href="/sitemap-0.xml">Sitemap</a>
			</div>
		</div>

		<script>
			const menuOpenBtn = document.getElementById("menu-open-btn") as HTMLButtonElement;
			const menuDialog = document.getElementById("menu-dialog") as HTMLDialogElement;
			const menuCloseBtn = document.getElementById("menu-dialog-close-btn") as HTMLButtonElement;

			menuOpenBtn.addEventListener("click", () => {
				menuDialog.showModal();
			});

			menuCloseBtn.addEventListener("click", () => {
				menuDialog.close();
			});

			menuDialog.addEventListener("click", event => {
				// Close the dialog on tapping the backdrop
				if (event.target === menuDialog) menuDialog.close();
			});
		</script>
	</body>
</html>
