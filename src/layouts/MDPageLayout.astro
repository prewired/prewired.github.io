---
import PageLayout from "./PageLayout.astro";
import importImage from "@scripts/dynamicImportImage";


interface Props {
	frontmatter: {
		title: string;
		desc: string;
		coverImage: {
			src: string;
			alt: string;
		};
		accent?: "pink" | "purple" | "blue";
	};
	headings: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings } = Astro.props;
const { title, desc, coverImage, accent } = frontmatter;

const coverImageData = await importImage(coverImage);
---

<PageLayout
	title={title}
	desc={desc}
	coverImageData={coverImageData}
	coverImageAlt={coverImage.alt}
	accent={accent}
	headings={headings}
>
	<slot />
</PageLayout>
