---
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';


interface Props {
	imgSrc: ImageMetadata;
	imgAlt: string;
	reverse?: boolean;
}

const { imgSrc, imgAlt, reverse } = Astro.props;
---

<section class="mt-0 max-md:pt-0">
	<div class={`flex flex-col ${reverse ? "md:flex-row-reverse" : "md:flex-row"} items-center lg:px-8`}>
		<Picture
			src={imgSrc}
			formats={["avif", "webp"]}
			alt={imgAlt}
			class="w-full h-48 md:h-108 object-cover md:rounded-lg"
			pictureAttributes={{ class: `w-full md:w-1/2 shrink-0 ${reverse ? "md:pl-24 md:max-lg:pr-4" : "md:pr-24 md:max-lg:pl-4"}` }}
		/>
		<div class="px-4 lg:pl-0 max-md:mt-4">
			<slot />
		</div>
	</div>
</section>
