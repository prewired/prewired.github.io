---
import { Picture } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import BookTicketsButton from "@components/BookTicketsButton.astro";
import logo from "@assets/logos/prewired-logo-no-text.png";
import cover from "@assets/photos/ws18_session.jpg";
import cover_ascii from "@assets/photos/ws18_session_ascii.png";
import overview from "@assets/photos/sh16_discuss.jpg";
import codebase from "@assets/logos/codebase-logo.png";
import hypercube from "@assets/logos/hypercube-logo.png";
import robotical from "@assets/logos/robotical-logo.png";
import uoe from "@assets/logos/uoe-logo.png";
import rpf from "@assets/logos/rpf-logo.png";


const sponsors = [
	{ name: "CodeBase", href: "https://thisiscodebase.com", src: codebase, style: "py-4" },
	{ name: "Hypercube", href: "https://wearehypercube.com", src: hypercube, style: "py-4" },
	{ name: "Raspberry Pi Foundation", href: "https://www.raspberrypi.org/", src: rpf, style: "py-2" },
	{ name: "Robotical", href: "https://robotical.io", src: robotical },
	{ name: "University of Edinburgh", href: "https://www.ed.ac.uk", src: uoe }
];

const coverImageAlt = "A room full of young people working on laptops at low and high tables";
// bg-linear-[170deg,#EDFCFF,#FAF6FE_400px,#FFF0F3_800px]
---

<BaseLayout
	title="Home"
	ogTitle="Welcome to Prewired!"
	desc="Welcome to Prewired, a free Edinburgh programming club for young people. If you're under 19 years old and interested in learning to code, or want support taking your passion further, you're in the right place!"
	type="website"
	coverImageData={cover}
	coverImageAlt={coverImageAlt}
>
	<!-- Cover -->
	<section class="relative flex flex-col-reverse lg:block lg:h-120 xl:h-140 lg:px-8 border-b overflow-hidden">
		<div class="relative max-w-360 mx-auto h-full flex flex-col justify-center z-10">
			<Picture priority
				src={logo}
				formats={["avif", "webp"]}
				alt="A pixelated map of Scotland with an asterisk centred on Edinburgh and two sets of curly braces around it"
				class="hidden xl:block absolute h-120 w-120 -top-12 -left-128 opacity-10"
			/>
			<div class="lg:w-md md:max-lg:mx-auto px-4 lg:px-0 py-6 text-center lg:text-left text-balance">
				<h1 class="mb-4 lg:mb-2 font-semibold text-3xl lg:text-4xl">
					Create anything you can think of at <span class="text-blue-750">Prewired</span>! 
				</h1>
				<p class="mb-8 font-[450]">
					The free, weekly programming club for young people in Edinburgh.
				</p>
				<div class="flex flex-col md:flex-row flex-wrap md:justify-center lg:justify-start gap-4">
					<BookTicketsButton />
					<a
						href="http://eepurl.com/dv2dPb"
						target="_blank" rel="noopener"
						class="px-4 py-3 bg-pink-600 rounded-md cursor-pointer text-white no-underline hover:border-transparent hover:bg-pink-800 active:bg-pink-900 transition"
					>
						Join our mailing list
					</a>
				</div>
			</div>
		</div>
		<div class="lg:absolute h-full w-full lg:w-[65%] max-w-360 top-0 right-0">
			<Picture priority
				src={cover_ascii}
				formats={["avif", "webp"]}
				alt=""
				class="absolute h-60 md:h-72 lg:h-112 xl:h-140 object-cover object-bottom sm:object-center mask-linear-178 mask-linear-from-80% mask-linear-to-90% lg:-mask-linear-85 lg:mask-linear-from-60% lg:mask-linear-to-90%"
			/>
			<Picture priority
				src={cover}
				formats={["avif", "webp"]}
				alt={coverImageAlt}
				class="h-60 md:h-72 lg:h-112 xl:h-140 object-cover object-bottom sm:object-center mask-linear-178 mask-linear-from-50% mask-linear-to-80% sm:mask-linear-from-60% lg:-mask-linear-85 lg:mask-linear-from-30% lg:mask-linear-to-60%"
			/>
		</div>
	</section>

	<!-- Special announcements -->
	<!-- <div class="h-8 border-b diastripe"></div>
	<section class="sm:text-center sm:text-balance">
		<div class="relative px-4 py-6 bg-blue-50">
			<p class="max-w-full mb-2 font-semibold text-base text-blue-750 uppercase">
				Announcement&nbsp;&nbsp;❄️&nbsp;&nbsp;1 Dec 2025
			</p>
			<h1 class="mb-0 font-bold text-xl md:text-2xl">
				Festive Party and End-of-Term
			</h1>
			<Picture priority
				src={santamarty}
				formats={["avif", "webp"]}
				alt="A Marty robot wearing a Santa hat"
				pictureAttributes={{ class: "hidden md:block absolute w-40 bottom-0 right-0" }}
			/>
		</div>
		<div class="border-y bg-blue-50">
			<div class="max-w-204 mx-auto pt-6 pb-3 px-4 md:px-12 border-x">
				<p>
					On 17 December we're hosting a <strong>special festive session</strong> in collaboration with Digital Skills 4 Girls!
				</p>
				<p>
					For more info and free tickets, <a href="https://buytickets.at/prewired/1951681" target="_blank" rel="noopener noreferrer">go to the event page</a>.
				</p>
				<p>
					For this end-of-term session there will be several festive-themed activities to choose from, as well as games and plenty of snacks. The desk area will also be set up for a regular Prewired session if you'd rather crack on with your usual projects.
				</p>
				<p>
					This will be our last session of the year&mdash;after this we'll be back on 7 January!
				</p>
			</div>
		</div>
	</section>
	<div class="h-8 border-b diastripe"></div> -->
	
	<!-- Overview -->
	<section class="flex flex-col lg:flex-row lg:items-center lg:justify-center">
		<div class="lg:w-1/2 lg:py-24 lg:border-r shrink-0">
			<Picture priority
				src={overview}
				formats={["avif", "webp"]}
				alt="Three teenagers coding on laptops while chatting to each other"
				class="h-60 lg:h-112 lg:w-[80%] lg:max-w-xl lg:float-right lg:mr-16 object-cover lg:rounded-lg"
			/>
		</div>
		<div class="md:w-3/4 md:max-lg:mx-auto lg:w-1/2 lg:ml-12 px-4 py-8 lg:py-0 sm:text-center lg:text-left">
			<h1 class="mb-4 font-semibold text-2xl md:text-3xl">
				What we do
			</h1>
			<p class="max-w-[42ch] sm:max-lg:mx-auto md:text-lg">
				If you're under 19 years old and interested in learning to code, or want support taking your passion further, you're in the right place!
			</p>
			<p class="max-w-[42ch] sm:max-lg:mx-auto mb-8 md:text-lg">
				Every Wednesday 5:30&ndash;7:30 PM, we meet at CodeBase Edinburgh. You can bring your own project to work on or chat to one of our volunteers about how to get started!
			</p>
			<a
				href="/activities/"
				class="block w-full sm:w-fit sm:mx-auto lg:mx-0 px-4 py-3 bg-blue-100 rounded-md cursor-pointer text-black text-center no-underline hover:bg-blue-700 hover:text-white active:bg-blue-900"
			>
				Read more about our activities
			</a>
		</div>
	</section>

	<!-- Impact -->
	<section class="bg-pink-50 border-y">
		<h1 class="font-semibold text-xl md:text-2xl text-center text-pink-700 mb-0 py-12 lg:border-b">
			Small team, large impact...
		</h1>
		<div class="flex flex-wrap justify-center gap-y-4 md:gap-y-8 max-w-7xl mx-auto pb-8 md:pb-0 lg:divide-x text-center *:w-1/3 *:min-w-66 md:*:py-12 lg:*:py-16 ">
			<div class="min-[83rem]:border-l">
				<p class="text-4xl mb-4">🧑‍💻</p>
				<p class="mb-2 lg:mb-4 font-semibold text-3xl lg:text-5xl text-pink-700">
					150+
				</p>
				<p>unique attendees in 2025</p>
			</div>
			<div>
				<p class="text-4xl mb-4">🗓️</p>
				<p class="mb-2 lg:mb-4 font-semibold text-3xl lg:text-5xl text-pink-700">
					50+
				</p>
				<p>events a year</p>
			</div>
			<div class="relative min-[83rem]:border-r">
				<p class="text-4xl mb-4">🍵</p>
				<p class="mb-2 lg:mb-4 font-semibold text-3xl lg:text-5xl text-pink-700">
					100%
				</p>
				<p>volunteer-run</p>
				<a
					href="/volunteering/"
					class="absolute -bottom-6 md:bottom-6 lg:bottom-10 right-14 px-4 py-2 bg-pink-600 hover:bg-pink-800 border-b-2 border-pink-900 active:border-b-0 active:mt-0.5 rounded-lg -rotate-3 font-semibold uppercase text-white no-underline"
				>
					Get involved!
				</a>
			</div>
		</div>
	</section>

	<!-- Sponsors -->
	<section class="text-center text-balance">
		<div class="max-w-5xl mx-auto pt-16 pb-8 lg:pb-20 min-[67rem]:border-x">
			<h1 class="max-md:text-xl mb-4">
				Sponsors & supporters
			</h1>
			<p class="max-w-full mb-0">
				In addition to the accommodation generously provided by CodeBase, Prewired could not exist without the support from our sponsors, donors, and supporters.
			</p>
		</div>
		<div class="relative md:border-y after:hidden after:xl:block after:absolute after:w-full after:h-px after:left-0 after:top-36 after:bg-gray-200">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row flex-wrap items-center justify-center md:divide-x md:divide-y">
				{ sponsors.map(({name, href, src, style}) => (
					<a href={href} target="_blank" rel="noopener" class="md:w-1/2 lg:w-1/3 max-md:px-4 py-2 lg:py-8 first:min-[83rem]:border-l nth-2:max-lg:border-r-0 nth-3:lg:max-[83rem]:border-r-0 nth-4:max-lg:border-r-0 nth-4:lg:border-l nth-4:lg:border-b-0 last:md:max-lg:border-l last:md:border-r border-gray-200 hover:bg-blue-50 transition">
						<Picture
							src={src}
							formats={["avif", "webp"]}
							alt={`${name} logo`}
							class={`w-auto h-18 md:h-20 mx-auto object-cover ${style}`}
						/>
					</a>
				))}
			</div>
		</div>
		<p class="max-w-5xl mx-auto mb-0 py-12 min-[67rem]:border-x border-gray-200">
			Thank you!
		</p>
	</section>
</BaseLayout>
