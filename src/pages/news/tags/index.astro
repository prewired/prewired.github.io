---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import coverPhoto from "@assets/photos/sh18_live.jpg";


const allPosts = await getCollection("posts");
const tags = [...new Set(allPosts.map(post => post.data.tags).flat())].sort((a, b) => a > b ? 1 : a === b ? 0 : -1);
---

<PageLayout
	title="All tags"
	desc="All tags used on the Prewired blog."
	coverImageData={coverPhoto}
	coverImageAlt="A computer screen with the text 'Prewired Presentations begin 13:00 Friday 27th July 2018'"
>
	<div class="px-4 lg:px-8 py-8">
		{ tags.map(tag => (
			<p>
				<a
					href={`/news/tags/${tag}/`}
					class="font-medium uppercase text-base text-black no-underline bg-blue-200 hover:bg-purple-200 rounded px-2 py-1 leading-0"
				>
					{ tag }
				</a>
			</p>
		)) }
	</div>
</PageLayout>
